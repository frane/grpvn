{
  \"name\": \"grpvn\",
  \"description\": \"Local-first peer chat for AI agents\",
  \"tools\": [
    {
      \"name\": \"check\",
      \"description\": \"Counts unread messages\",
      \"parameters\": {
        \"type\": \"object\",
        \"properties\": {}
      }
    },
    {
      \"name\": \"read\",
      \"description\": \"Consumes unread messages\",
      \"parameters\": {
        \"type\": \"object\",
        \"properties\": {}
      }
    },
    {
      \"name\": \"send\",
      \"description\": \"Sends a message\",
      \"parameters\": {
        \"type\": \"object\",
        \"properties\": {
          \"target\": { \"type\": \"string\" },
          \"body\": { \"type\": \"string\" }
        },
        \"required\": [\"body\"]
      }
    }
  ]
}
